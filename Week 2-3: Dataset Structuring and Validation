import os
import glob
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# =====================================================================
# PART 0: DIRECTORY SETUP & RAW RE-CONSTRUCTION FOR Q1
# =====================================================================
data_folder = "/Users/samikshadubey/Downloads/IDX Code/Files"

# Re-loading raw files briefly to capture the pre-filtered property type share for Q1
listing_files = sorted(glob.glob(os.path.join(data_folder, "CRMLSListing*.csv")))
listing_dfs = [pd.read_csv(file_path, low_memory=False) for file_path in listing_files]
listings_master = pd.concat(listing_dfs, ignore_index=True)

# Load the working Week 1 dataset
listings = pd.read_csv(os.path.join(data_folder, "listings.csv"), low_memory=False)

# =====================================================================
# PART 1: DATASET UNDERSTANDING
# =====================================================================
print("--- Listing DATASET VOLUME ---")
print(f"Total Rows: {listings.shape[0]}")
print(f"Total Columns: {listings.shape[1]}\n")

print("--- 1. LISTINGS STRUCTURE ---")
print(f"Rows: {listings.shape[0]:,}, Columns: {listings.shape[1]}")
print("\n--- Column Data Types (First 30) ---")
print(listings.dtypes.head(30)) 

# =====================================================================
# PART 2: MISSING VALUE ANALYSIS
# =====================================================================
print("\n--- 2. MISSING VALUE ANALYSIS ---")
null_counts = listings.isnull().sum()
null_percentages = (null_counts / len(listings)) * 100

missing_report = pd.DataFrame({'Null Count': null_counts, 'Percentage': null_percentages})
print("\n--- Missing Value Report (First 40 Columns) ---")
print(missing_report.head(40))

high_missing_cols = missing_report[missing_report['Percentage'] > 90].index.tolist()

print("\nColumns with >90% missing values to consider dropping:")
print(high_missing_cols)
print(f"\nTotal columns with >90% Missing Values: {len(high_missing_cols)}")

# Separate market analysis fields from metadata fields
# Metadata fields: Administrative data generated by the MLS software backend to track, identify, and manage database records.
# Market Analysis fields: Real world metrics that describe the physical property traits and the financial details of the transaction.

metadata_fields = [
    'ListingKey', 
    'ListingId', 
    'MlsStatus', 
    'OriginatingSystemName', 
    'ModificationTimestamp'
]

market_analysis_fields = [
    # 'ClosePrice', # NO CLOSE price in active listings
    'ListPrice', 
    'OriginalListPrice', 
    'LivingArea', 
    'LotSizeAcres', 
    'BedroomsTotal', 
    'BathroomsTotalInteger', 
    'DaysOnMarket', 
    'YearBuilt', 
    'CountyOrParish'
]

# Run summary statistics for active listings fields
print("\n--- MARKET ANALYSIS FIELDS STATISTICAL SUMMARY ---")
market_summary = listings[market_analysis_fields].describe()
print(market_summary)

# Core fields we MUST retain regardless of missing data
core_listing_fields = [
    'ListPrice', 'OriginalListPrice', 'LivingArea', 'LotSizeAcres', 
    'BedroomsTotal', 'BathroomsTotalInteger', 'DaysOnMarket', 'YearBuilt', 'CountyOrParish'
]

# Drop columns that have >90% missing values UNLESS they are in our core fields list
cols_to_drop = [col for col in high_missing_cols if col not in core_listing_fields]

# Applying drop to create a cleaner dataset
listings_cleaned = listings.drop(columns=cols_to_drop)
print(f"\nDropped {len(cols_to_drop)} columns. Remaining columns in listings_cleaned: {listings_cleaned.shape[1]}")

# =====================================================================
# PART 3: NUMERIC DISTRIBUTION & OUTLIER REVIEW
# =====================================================================
print("\n--- LISTINGS DATA: STATISTICS & OUTLIERS ---")

numeric_fields = [
    'ListPrice', 'OriginalListPrice',
    'LivingArea', 'LotSizeAcres',
    'BedroomsTotal', 'BathroomsTotalInteger',
    'DaysOnMarket', 'YearBuilt'
]

# Statistical Summary
print(listings_cleaned[numeric_fields].describe())

# Percentiles, Outliers & Plots Loop
for col in numeric_fields:
    data = listings_cleaned[col].dropna()

    if data.empty:
        continue

    # Percentiles
    q1, median, q3 = np.percentile(data, [25, 50, 75])
    p99 = np.percentile(data, 99)

    # IQR Outliers
    iqr = q3 - q1
    lower = q1 - 3 * iqr
    upper = q3 + 3 * iqr
    outliers = data[(data < lower) | (data > upper)]

    print(f"\n🔹 Field: {col}")
    print(f"25%: {q1:.2f} | Median: {median:.2f} | 75%: {q3:.2f} | 99%: {p99:.2f}")
    print(f"Outliers: {len(outliers)} ({len(outliers)/len(data)*100:.2f}%)")

    # Histogram & Boxplot
    plt.figure(figsize=(10, 4))

    plt.subplot(1, 2, 1)
    sns.histplot(data, bins=30, kde=True, color="steelblue")
    plt.title(f"{col} Histogram")

    plt.subplot(1, 2, 2)
    sns.boxplot(y=data, color="steelblue")
    plt.title(f"{col} Boxplot")

    plt.tight_layout()
    plt.show()

# =====================================================================
# PART 4: SUGGESTED INTERN QUESTIONS
# =====================================================================

print("\nQ1: PROPERTY TYPE SHARE (LISTINGS MASTER)")
prop_shares = listings_master['PropertyType'].value_counts(normalize=True) * 100
print(prop_shares)

print("\nQ2: DAYS ON MARKET DISTRIBUTION (LISTINGS CLEANED)")
print(f"Median Days on Market: {listings_cleaned['DaysOnMarket'].median()}")
print(f"Average Days on Market: {listings_cleaned['DaysOnMarket'].mean():.2f}")

print("\nQ3: HIGHEST MEDIAN PRICE BY COUNTY (LISTINGS CLEANED)")
county_prices = listings_cleaned.groupby('CountyOrParish')['ListPrice'].median().sort_values(ascending=False)
print(county_prices.head(10))

